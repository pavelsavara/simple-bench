<div class="form-field">
	<label>Name:</label>
	<div>
		<InputText @bind-Value="Address.Name" data-testid="address-name" />
		<ValidationMessage For="@(() => Address.Name)" />
	</div>
</div>

<div class="form-field">
	<label>Line 1:</label>
	<div>
		<InputText @bind-Value="Address.Line1" data-testid="address-line1" />
		<ValidationMessage For="@(() => Address.Line1)" />
	</div>
</div>

<div class="form-field">
	<label>Line 2:</label>
	<div>
		<InputText @bind-Value="Address.Line2" data-testid="address-line2" />
		<ValidationMessage For="@(() => Address.Line2)" />
	</div>
</div>

<div class="form-field">
	<label>City:</label>
	<div>
		<InputText @bind-Value="Address.City" data-testid="address-city" />
		<ValidationMessage For="@(() => Address.City)" />
	</div>
</div>

<div class="form-field">
	<label>Region:</label>
	<div>
		<InputText @bind-Value="Address.Region" data-testid="address-region" />
		<ValidationMessage For="@(() => Address.Region)" />
	</div>
</div>

<div class="form-field">
	<label>Postal code:</label>
	<div>
		<InputText @bind-Value="Address.PostalCode" data-testid="address-postalcode" />
		<ValidationMessage For="@(() => Address.PostalCode)" />
	</div>
</div>

@code {
	[Parameter, EditorRequired] public Address Address { get; set; } = new();
}